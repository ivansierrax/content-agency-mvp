# content_agency_mvp — environment variables
# Copy to `.env` and fill values. NEVER commit `.env`.
# Production values live in Railway env settings.

# === Supabase ===
SUPABASE_URL=https://cysdcdrkibsnxjnewksn.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxx

# === Anthropic ===
# Use a dedicated key for this project (separate from n8n production key for cost tracking)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxx

# === Per-brand secret encryption (D-008) ===
# AES-256-GCM key, 32 raw bytes base64-encoded.
# Generate with: openssl rand -base64 32
# DO NOT rotate without re-encrypting all brand_configs rows.
MASTER_ENCRYPTION_KEY=base64-32-bytes-here

# === Sentry ===
SENTRY_DSN=https://xxxxxxxx@oxxxxxxxxxxxx.ingest.us.sentry.io/xxxxxxxxxxxxx
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=development

# === Railway / runtime ===
NODE_ENV=development
PORT=3000

# === Notion (Day 5+) ===
# Integration token. MVP reuses the existing Hashtag agency token —
# Day 9 cleanup migrates to a scoped read-only integration.
NOTION_API_KEY=ntn_xxxxxxxxxxxxxx
NOTION_VERSION=2025-09-03

# === Admin endpoints (optional) ===
# Shared secret for /admin/* routes. If unset, admin endpoints are open
# (acceptable inside Railway's private network for MVP single-tenant ops).
ADMIN_TOKEN=

# === Designer (Day 6) ===
# HCTI Hosted API for HTML→PNG slide rendering. Same account used by n8n production.
HCTI_USER_ID=
HCTI_API_KEY=

# Gemini API key for image generation (gemini-2.5-flash-image).
GEMINI_API_KEY=

# Supabase Storage bucket for rendered slide images. Public read, 10MB cap, image MIME types only.
MVP_CONTENT_BUCKET=mvp-content

# === Per-brand IG / LinkedIn tokens ===
# Stored encrypted in Supabase brand_configs table; not env vars
